{{!
    @template local_cesubmit/my/dashboard

    Full CE compliance dashboard page.
}}

{{! Section 1: Certification Status }}
{{#hascertifications}}
<div class="card mb-4">
    <div class="card-header"><h4 class="mb-0">{{#str}}certificationstatus, local_cesubmit{{/str}}</h4></div>
    <div class="card-body">
        {{#certifications}}
        <div class="d-flex justify-content-between align-items-center mb-3 pb-2 border-bottom">
            <div>
                <strong>{{name}}</strong>
                {{#hasexpiry}}
                <div class="small text-muted">{{#str}}certifieduntil, local_cesubmit{{/str}}: {{validuntil}}</div>
                {{/hasexpiry}}
            </div>
            <div class="text-right">
                {{#status_compliant}}<span class="badge badge-success">{{statuslabel}}</span>{{/status_compliant}}
                {{#status_inprogress}}<span class="badge badge-warning">{{statuslabel}}</span>{{/status_inprogress}}
                {{#status_overdue}}<span class="badge badge-danger">{{statuslabel}}</span>{{/status_overdue}}
                {{#hasdaysremaining}}
                <div class="small text-muted">{{daysremaining}}</div>
                {{/hasdaysremaining}}
            </div>
        </div>
        {{/certifications}}
    </div>
</div>
{{/hascertifications}}
{{^hascertifications}}
<div class="alert alert-info">{{nocertificationstext}}</div>
{{/hascertifications}}

{{! Section 2: Credit Progress }}
{{#hasframeworks}}
<div class="card mb-4">
    <div class="card-header"><h4 class="mb-0">{{#str}}creditprogress, local_cesubmit{{/str}}</h4></div>
    <div class="card-body">
        {{#frameworks}}
        <div class="mb-4">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h5 class="mb-0">{{name}}</h5>
                {{#status_compliant}}<span class="badge badge-success">{{statuslabel}}</span>{{/status_compliant}}
                {{#status_inprogress}}<span class="badge badge-warning">{{statuslabel}}</span>{{/status_inprogress}}
                {{#status_overdue}}<span class="badge badge-danger">{{statuslabel}}</span>{{/status_overdue}}
            </div>
            <div class="progress mb-1" style="height: 20px;" role="progressbar"
                 aria-valuenow="{{percentage}}" aria-valuemin="0" aria-valuemax="100"
                 aria-label="{{earned}} of {{required}} credits">
                {{#status_compliant}}
                <div class="progress-bar bg-success" style="width: {{percentage}}%">{{percentage}}%</div>
                {{/status_compliant}}
                {{#status_inprogress}}
                <div class="progress-bar bg-warning" style="width: {{percentage}}%">{{percentage}}%</div>
                {{/status_inprogress}}
                {{#status_overdue}}
                <div class="progress-bar bg-danger" style="width: {{percentage}}%">{{percentage}}%</div>
                {{/status_overdue}}
            </div>
            <div class="small text-muted">{{earned}} of {{required}} credits earned</div>
            {{#isprorated}}
            <div class="small text-info">Prorated requirement: {{proratedcredits}} credits (full requirement: {{fullrequired}})</div>
            {{/isprorated}}
            {{#hascreditsgap}}
            <div class="small text-muted">{{creditsgaptext}}</div>
            {{/hascreditsgap}}
            {{#hasdeadline}}
            <div class="small text-muted mt-1">{{#str}}deadline, local_cesubmit{{/str}}: {{deadline}}</div>
            {{/hasdeadline}}
            {{#isoverdue}}
            <div class="small text-danger font-weight-bold">{{#str}}overdue, local_cesubmit{{/str}}</div>
            {{/isoverdue}}
            {{^isoverdue}}
            {{#hasdaysremaining}}
            <div class="small {{#days_green}}text-success{{/days_green}}{{#days_amber}}text-warning{{/days_amber}}{{#days_red}}text-danger{{/days_red}}">{{daysremainingtext}}</div>
            {{/hasdaysremaining}}
            {{/isoverdue}}
            {{#hascategories}}
            <div class="mt-3">
                <h6 class="text-muted small font-weight-bold text-uppercase">
                    {{#str}}categoryrequirements, local_cesubmit{{/str}}
                </h6>
                {{#categories}}
                <div class="mb-2">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <span class="small">{{categoryname}}</span>
                        <span class="small">
                            {{#compliant}}
                            <span class="badge badge-success">{{earned}} / {{mincredits}} &#10003;</span>
                            {{/compliant}}
                            {{#notcompliant}}
                            <span class="badge badge-warning">{{earned}} / {{mincredits}} required</span>
                            {{/notcompliant}}
                        </span>
                    </div>
                    <div class="progress" style="height:6px;">
                        <div class="progress-bar {{#compliant}}bg-success{{/compliant}}{{#notcompliant}}bg-warning{{/notcompliant}}"
                            role="progressbar" style="width:{{pctwidth}}%"
                            aria-valuenow="{{pct}}" aria-valuemin="0" aria-valuemax="100">
                        </div>
                    </div>
                    {{#hascategorygap}}
                    <div class="small text-muted">{{categorygaptext}}</div>
                    {{/hascategorygap}}
                </div>
                {{/categories}}
                {{#allcategorycompliant}}{{#hascreditsgap}}
                <div class="small text-success mt-2">
                    &#10003; Category requirements met &mdash; {{creditsgap}} more total credits needed
                </div>
                {{/hascreditsgap}}{{/allcategorycompliant}}
            </div>
            {{/hascategories}}
        </div>
        {{/frameworks}}
    </div>
</div>
{{/hasframeworks}}
{{^hasframeworks}}
<div class="alert alert-info">{{nocreditstext}}</div>
{{/hasframeworks}}

{{! Section 3: Credit History }}
{{#historybyfw}}
{{#hasentries}}
<div class="card mb-4">
    <div class="card-header"><h5 class="mb-0">{{frameworkname}} &mdash; {{credithistorylabel}}</h5></div>
    <div class="card-body p-0">
        <table class="table table-striped mb-0">
            <thead>
                <tr>
                    <th>{{datelabel}}</th>
                    <th>{{activitylabel}}</th>
                    <th>{{providerlabel}}</th>
                    <th>{{credittypelabel}}</th>
                    <th class="text-right">{{hourslabel}}</th>
                </tr>
            </thead>
            <tbody>
                {{#entries}}
                <tr{{#revoked}} class="text-muted" style="text-decoration: line-through;"{{/revoked}}>
                    <td>{{date}}</td>
                    <td>{{activity}}</td>
                    <td>{{provider}}</td>
                    <td>{{credittype}}</td>
                    <td class="text-right">{{hours}}</td>
                </tr>
                {{/entries}}
            </tbody>
        </table>
    </div>
</div>
{{/hasentries}}
{{/historybyfw}}
